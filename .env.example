# --- Miharbor environment file ------------------------------------------
# Copy to `.env` and fill in the required values. Keep `.env` OUT of git.
# The three *_SECRET / *_HASH / *_KEY values below are all mandatory for a
# production deployment.
# ------------------------------------------------------------------------

# Required: mihomo REST API Bearer token. This must be the same string as
# mihomo's `secret:` field in its config.yaml.
MIHOMO_API_SECRET=

# Required: Argon2id hash of your admin password. Generate with:
#   docker run --rm oven/bun:1.3.11-alpine \
#     bun -e 'console.log(await Bun.password.hash("your-password"))'
# Paste the resulting "$argon2id$..." string here.
MIHARBOR_AUTH_PASS_HASH=

# Required: 32-byte (64 hex chars) key for snapshot-vault encryption.
# Generate with:
#   openssl rand -hex 32
# CRITICAL: losing this key makes every historical snapshot unreadable.
# Back it up separately from the miharbor_data volume.
MIHARBOR_VAULT_KEY=

# Optional tunables — safe to leave commented out to use defaults.
# MIHARBOR_LOG_LEVEL=info
# MIHARBOR_AUTO_ROLLBACK=true
# MIHARBOR_SNAPSHOT_RETENTION_COUNT=50
# MIHARBOR_SNAPSHOT_RETENTION_DAYS=30
