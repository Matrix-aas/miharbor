{
  "name": "miharbor-web",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,vue}\" --max-warnings 0",
    "lint:a11y": "MIHARBOR_A11Y=1 eslint \"src/**/*.{ts,vue}\"",
    "test": "vitest run",
    "e2e": "playwright test --config playwright.config.ts",
    "check-bundle": "bun run scripts/check-bundle-size.ts"
  },
  "dependencies": {
    "@vueuse/core": "~12.3.0",
    "class-variance-authority": "~0.7.1",
    "clsx": "~2.1.1",
    "diff2html": "~3.4.51",
    "lucide-vue-next": "~0.468.0",
    "miharbor-shared": "workspace:*",
    "monaco-editor": "~0.52.2",
    "monaco-yaml": "~5.4.1",
    "pinia": "~2.3.0",
    "radix-vue": "~1.9.11",
    "tailwind-merge": "~2.5.5",
    "vue": "~3.5.13",
    "vue-i18n": "~10.0.5",
    "vue-router": "~4.5.0",
    "yaml": "~2.8.3"
  },
  "devDependencies": {
    "@playwright/test": "~1.50.1",
    "@types/node": "~22.10.2",
    "@vitejs/plugin-vue": "~5.2.1",
    "@vue/test-utils": "~2.4.6",
    "autoprefixer": "~10.4.20",
    "eslint-plugin-vue": "~9.32.0",
    "eslint-plugin-vuejs-accessibility": "~2.4.1",
    "jsdom": "~25.0.1",
    "postcss": "~8.4.49",
    "tailwindcss": "~3.4.17",
    "vite": "~6.0.7",
    "vitest": "~2.1.8",
    "vue-eslint-parser": "~9.4.3",
    "vue-tsc": "~2.2.0"
  }
}
