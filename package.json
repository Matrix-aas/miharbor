{
  "name": "miharbor",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "bun --filter miharbor-web dev",
    "server:dev": "bun --filter miharbor-server dev",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "bun run --filter='*' lint",
    "test": "bun test",
    "e2e": "bun --filter miharbor-web e2e",
    "i18n:check": "bun run scripts/i18n-validator.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "~1.3.12",
    "eslint": "~10.2.1",
    "eslint-plugin-vue": "~10.8.0",
    "eslint-plugin-vuejs-accessibility": "~2.5.0",
    "husky": "~9.1.7",
    "lint-staged": "~15.4.3",
    "prettier": "~3.4.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.58.2",
    "vue-eslint-parser": "~10.4.0"
  }
}
