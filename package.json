{
  "name": "miharbor",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "bun --filter miharbor-web dev",
    "server:dev": "bun --filter miharbor-server dev",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "bun run --filter='*' lint",
    "test": "bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "~1.3.12",
    "eslint": "~9.19.0",
    "husky": "~9.1.7",
    "lint-staged": "~15.4.3",
    "prettier": "~3.4.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.24.1"
  }
}
